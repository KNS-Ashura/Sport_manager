{% extends 'base.html.twig' %}

{% block title %}Tournois Disponibles - SportManager{% endblock %}

{% block body %}
<h1>Tournois Disponibles</h1>
<p>Inscrivez-vous aux tournois pour participer.</p>

<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem;">
    {% for tournament in tournaments %}
        <div class="card">
            <h3>{{ tournament.tournamentName }}</h3>
            <p><strong>Sport :</strong> {{ tournament.sport }}</p>
            <p>{{ tournament.description }}</p>
            
            <ul style="list-style: none; padding: 0; font-size: 0.9rem;">
                <li>Dates : {{ tournament.startDate|date('d/m/Y') }} - {{ tournament.endDate|date('d/m/Y') }}</li>
                <li>Lieu : {{ tournament.location }}</li>
                <li>Participants max : {{ tournament.maxParticipants }}</li>
            </ul>

            <form action="{{ path('app_user_tournament_register', {id: tournament.id}) }}" method="POST" style="margin-top: 1rem;">
                <button type="submit" class="btn" style="width: 100%;">S'inscrire</button>
            </form>
        </div>
    {% else %}
        <p>Aucun tournoi disponible.</p>
    {% endfor %}
</div>
{% endblock %}
