{% extends 'base.html.twig' %}

{% block title %}Mes Inscriptions - SportManager{% endblock %}

{% block body %}
<h1>Mes Inscriptions</h1>
<p>Suivez le statut de vos demandes de participation.</p>

{% if registrations is empty %}
    <p>Vous n'êtes inscrit à aucun tournoi.</p>
{% else %}
    <table>
        <thead>
            <tr>
                <th>Tournoi</th>
                <th>Sport</th>
                <th>Date Inscription</th>
                <th>Statut</th>
            </tr>
        </thead>
        <tbody>
            {% for reg in registrations %}
                <tr>
                    <td>{{ reg.tournament.tournamentName }}</td>
                    <td>{{ reg.tournament.sport }}</td>
                    <td>{{ reg.registrationDate|date('d/m/Y') }}</td>
                    <td>
                        {% if reg.status == 'confirmed' %}
                            <span style="color: green; font-weight: bold;">Confirmé</span>
                        {% elseif reg.status == 'pending' %}
                            <span style="color: orange; font-weight: bold;">En attente</span>
                        {% else %}
                            <span style="color: red; font-weight: bold;">Refusé</span>
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endif %}
{% endblock %}
