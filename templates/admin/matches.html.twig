{% extends 'base.html.twig' %}

{% block title %}Gestion des Matchs - SportManager{% endblock %}

{% block body %}
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h1>Gestion des Matchs</h1>
    <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary">Retour Admin</a>
</div>

<div class="card">
    <h2>Créer un match</h2>
    <form method="post" action="{{ path('admin_matches_create') }}" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div>
            <label>Tournoi</label>
            <select name="tournamentId" required>
                {% for t in tournaments %}
                    <option value="{{ t.id }}">{{ t.tournamentName }}</option>
                {% endfor %}
            </select>
        </div>
        <div>
            <label>Date du match</label>
            <input type="datetime-local" name="matchDate" required>
        </div>
        <div>
            <label>Joueur 1</label>
            <select name="player1Id" required>
                {% for u in users %}
                    <option value="{{ u.id }}">{{ u.username }}</option>
                {% endfor %}
            </select>
        </div>
        <div>
            <label>Joueur 2</label>
            <select name="player2Id" required>
                {% for u in users %}
                    <option value="{{ u.id }}">{{ u.username }}</option>
                {% endfor %}
            </select>
        </div>
        <button type="submit" class="btn" style="grid-column: 1 / span 2;">Créer le match</button>
    </form>
</div>

<h2>Liste des matchs</h2>
<table>
    <thead>
        <tr>
            <th>Tournoi</th>
            <th>Joueurs</th>
            <th>Score</th>
            <th>Date</th>
            <th>Statut</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for m in matches %}
            <tr>
                <td>{{ m.tournament.tournamentName }}</td>
                <td>{{ m.player1.username }} vs {{ m.player2.username }}</td>
                <td>
                    <form action="{{ path('admin_matches_update', {id: m.id}) }}" method="post" style="display:flex; gap:0.2rem;">
                        <input type="number" name="scorePlayer1" value="{{ m.scorePlayer1 }}" style="width:50px;">
                        <input type="number" name="scorePlayer2" value="{{ m.scorePlayer2 }}" style="width:50px;">
                        <button type="submit" class="btn" style="padding: 0.2rem 0.5rem;">OK</button>
                    </form>
                </td>
                <td>{{ m.matchDate|date('d/m/Y H:i') }}</td>
                <td>{{ m.status }}</td>
                <td>
                    <form action="{{ path('admin_matches_delete', {id: m.id}) }}" method="post" onsubmit="return confirm('Supprimer ?');">
                        <button type="submit" style="color:red; background:none; border:none; cursor:pointer;">Supprimer</button>
                    </form>
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}
