{% extends 'base.html.twig' %}

{% block title %}Gestion des Inscriptions - SportManager{% endblock %}

{% block body %}
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h1>Gestion des Inscriptions</h1>
    <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary">Retour Admin</a>
</div>

<div class="card">
    <h2>Inscrire un joueur</h2>
    <form method="post" action="{{ path('admin_registrations_create') }}" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div>
            <label>Joueur</label>
            <select name="playerId" required>
                {% for user in users %}
                    <option value="{{ user.id }}">{{ user.username }} ({{ user.emailAddress }})</option>
                {% endfor %}
            </select>
        </div>
        <div>
            <label>Tournoi</label>
            <select name="tournamentId" required>
                {% for tournament in tournaments %}
                    <option value="{{ tournament.id }}">{{ tournament.tournamentName }}</option>
                {% endfor %}
            </select>
        </div>
        <button type="submit" class="btn" style="grid-column: 1 / span 2;">Inscrire le joueur</button>
    </form>
</div>

<h2>Demandes en cours et Inscriptions</h2>
<table>
    <thead>
        <tr>
            <th>Joueur</th>
            <th>Tournoi</th>
            <th>Date</th>
            <th>Statut</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for reg in registrations %}
            <tr>
                <td>{{ reg.player.username }}</td>
                <td>{{ reg.tournament.tournamentName }}</td>
                <td>{{ reg.registrationDate|date('d/m/Y') }}</td>
                <td>{{ reg.status }}</td>
                <td>
                    {% if reg.status == 'pending' %}
                        <form action="{{ path('admin_registrations_status', {id: reg.id}) }}" method="post" style="display:inline;">
                            <input type="hidden" name="status" value="confirmed">
                            <button type="submit" class="btn" style="background: green; padding: 0.2rem 0.5rem;">Confirmer</button>
                        </form>
                        <form action="{{ path('admin_registrations_status', {id: reg.id}) }}" method="post" style="display:inline;">
                            <input type="hidden" name="status" value="rejected">
                            <button type="submit" class="btn" style="background: orange; padding: 0.2rem 0.5rem;">Rejeter</button>
                        </form>
                    {% endif %}
                    <form action="{{ path('admin_registrations_delete', {id: reg.id}) }}" method="post" style="display:inline;" onsubmit="return confirm('Supprimer ?');">
                        <button type="submit" style="color:red; background:none; border:none; cursor:pointer;">Supprimer</button>
                    </form>
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}
