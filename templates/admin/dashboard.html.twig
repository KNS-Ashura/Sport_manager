{% extends 'base.html.twig' %}

{% block title %}Administration - SportManager{% endblock %}

{% block body %}
<h1>Panel d'administration</h1>

<div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem;">
    <div class="card">
        <h2>Tournois</h2>
        <p>Gérez les tournois sportifs, les lieux et les dates.</p>
        <a href="{{ path('admin_tournaments') }}" class="btn">Gérer les tournois</a>
    </div>

    <div class="card">
        <h2>Inscriptions</h2>
        <p>Validez ou refusez les demandes des joueurs.</p>
        <a href="{{ path('admin_registrations') }}" class="btn">Gérer les inscriptions</a>
    </div>

    <div class="card">
        <h2>Matchs</h2>
        <p>Gérez la planification et les scores des matchs.</p>
        <a href="{{ path('admin_matches') }}" class="btn">Gérer les matchs</a>
    </div>

    <div class="card">
        <h2>Statistiques</h2>
        <p>Accès aux statistiques globales du système.</p>
        <button class="btn btn-secondary" disabled>Bientôt disponible</button>
    </div>
</div>
{% endblock %}
