{% extends 'base.html.twig' %}

{% block title %}Gestion des Tournois - SportManager{% endblock %}

{% block body %}
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h1>Gestion des Tournois</h1>
    <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary">Retour Admin</a>
</div>

<div class="card">
    <h2>Nouveau Tournoi</h2>
    <form method="post" action="{{ path('admin_tournaments_create') }}" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div>
            <label>Nom</label>
            <input name="tournamentName" required>
        </div>
        <div>
            <label>Sport</label>
            <input name="sport" required>
        </div>
        <div>
            <label>Date Début</label>
            <input type="datetime-local" name="startDate" required>
        </div>
        <div>
            <label>Date Fin</label>
            <input type="datetime-local" name="endDate" required>
        </div>
        <div>
            <label>Lieu</label>
            <input name="location">
        </div>
        <div>
            <label>Max participants</label>
            <input type="number" name="maxParticipants" required>
        </div>
        <div style="grid-column: 1 / span 2;">
            <label>Description</label>
            <textarea name="description" required></textarea>
        </div>
        <div>
            <label>Organisateur</label>
            <select name="organizerId" required>
                {% for user in users %}
                    <option value="{{ user.id }}">{{ user.username }}</option>
                {% endfor %}
            </select>
        </div>
        <button type="submit" class="btn" style="grid-column: 1 / span 2;">Créer le tournoi</button>
    </form>
</div>

<h2>Liste des tournois</h2>
<table>
    <thead>
        <tr>
            <th>Nom</th>
            <th>Sport</th>
            <th>Lieu</th>
            <th>Dates</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for tournament in tournaments %}
            <tr>
                <td>{{ tournament.tournamentName }}</td>
                <td>{{ tournament.sport }}</td>
                <td>{{ tournament.location }}</td>
                <td>{{ tournament.startDate|date('d/m/Y') }} - {{ tournament.endDate|date('d/m/Y') }}</td>
                <td>
                    <a href="{{ path('admin_tournaments_edit', {id: tournament.id}) }}">Modifier</a>
                    <form action="{{ path('admin_tournaments_delete', {id: tournament.id}) }}" method="post" style="display:inline;" onsubmit="return confirm('Supprimer ce tournoi ?');">
                        <button type="submit" style="color:red; background:none; border:none; cursor:pointer; padding:0;">Supprimer</button>
                    </form>
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}
