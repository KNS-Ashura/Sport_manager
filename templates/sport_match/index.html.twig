{% extends 'base.html.twig' %}

{% block title %}Mes Matchs - SportManager{% endblock %}

{% block body %}
<h1>Mes Matchs</h1>
<p>Retrouvez ici tous vos matchs et saisissez vos scores.</p>

{% if matches is empty %}
    <p>Vous n'avez aucun match prévu.</p>
{% else %}
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem;">
        {% for match in matches %}
            <div class="card">
                <p><strong>Tournoi :</strong> {{ match.tournament.tournamentName }}</p>
                <p><strong>Statut :</strong> {{ match.status|upper }}</p>
                
                <div style="display: flex; justify-content: space-between; align-items: center; margin: 1rem 0; background: #eee; padding: 1rem;">
                    <div style="text-align: center;">
                        <div>{{ match.player1.username }}</div>
                        <div style="font-size: 1.5rem; font-weight: bold;">{{ match.scorePlayer1 ?? '-' }}</div>
                    </div>
                    <div>VS</div>
                    <div style="text-align: center;">
                        <div>{{ match.player2.username }}</div>
                        <div style="font-size: 1.5rem; font-weight: bold;">{{ match.scorePlayer2 ?? '-' }}</div>
                    </div>
                </div>

                {% if match.status != 'finished' %}
                    <form action="{{ path('app_user_match_score', {id: match.id}) }}" method="POST" style="display: flex; gap: 0.5rem;">
                        <input type="number" name="score" placeholder="Mon score" required>
                        <button type="submit" class="btn">Valider</button>
                    </form>
                {% endif %}
                
                <p style="font-size: 0.8rem; color: #666; margin-top: 1rem;">
                    Date : {{ match.matchDate|date('d/m/Y H:i') }}
                </p>
            </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
