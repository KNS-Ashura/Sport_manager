{% extends 'base.html.twig' %}

{% block title %}Mon Dashboard - SportManager{% endblock %}

{% block body %}
<h1>Bonjour, {{ app.user.firstName }} !</h1>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
    
    <div class="card">
        <h2>Dernier Match</h2>
        {% if matches is empty %}
            <p>Aucun match prévu.</p>
        {% else %}
            {% set nextMatch = matches|first %}
            <div style="border: 1px solid #eee; padding: 1rem; border-radius: 4px;">
                <p><strong>Tournoi :</strong> {{ nextMatch.tournament.tournamentName }}</p>
                <p>{{ nextMatch.player1.username }} VS {{ nextMatch.player2.username }}</p>
                <p>Date : {{ nextMatch.matchDate|date('d/m/Y H:i') }}</p>
                <a href="{{ path('app_user_matches') }}" class="btn">Gérer mes matchs</a>
            </div>
        {% endif %}
    </div>

    <div class="card">
        <h2>Inscriptions</h2>
        {% if registrations is empty %}
            <p>Aucune inscription en cours.</p>
        {% else %}
            <ul>
                {% for reg in registrations|slice(0, 3) %}
                    <li>{{ reg.tournament.tournamentName }} - {{ reg.status }}</li>
                {% endfor %}
            </ul>
            <a href="{{ path('app_user_registrations') }}" class="btn">Toutes mes inscriptions</a>
        {% endif %}

        <h2 style="margin-top: 2rem;">Actions</h2>
        <a href="{{ path('app_user_tournaments') }}" class="btn" style="width: 100%; text-align: center; box-sizing: border-box;">
            Chercher un tournoi
        </a>
    </div>
</div>
{% endblock %}
