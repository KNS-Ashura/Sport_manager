{% extends 'base.html.twig' %}

{% block title %}Connexion - SportManager{% endblock %}

{% block body %}
<div style="max-width: 450px; margin: 4rem auto;">
    <div class="card">
        <h1 style="text-align: center; margin-bottom: 2rem;">Connexion</h1>

        <form method="post">
            {% if error %}
                <div class="flash flash-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            {% if app.user %}
                <div style="margin-bottom: 1.5rem; text-align: center;">
                    Vous êtes connecté en tant que <strong>{{ app.user.userIdentifier }}</strong>.
                    <br><br>
                    <a href="{{ path('app_logout') }}" class="btn btn-danger">Déconnexion</a>
                </div>
            {% else %}
                <div style="margin-bottom: 1.5rem;">
                    <label for="inputEmailAddress" style="display: block; margin-bottom: 0.5rem; color: var(--text-dim);">Email</label>
                    <input type="email" value="{{ last_username }}" name="emailAddress" id="inputEmailAddress" autocomplete="email" required autofocus placeholder="email@exemple.com">
                </div>

                <div style="margin-bottom: 1.5rem;">
                    <label for="inputPassword" style="display: block; margin-bottom: 0.5rem; color: var(--text-dim);">Mot de passe</label>
                    <input type="password" name="password" id="inputPassword" autocomplete="current-password" required placeholder="••••••••">
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div style="margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
                    <input type="checkbox" name="_remember_me" id="_remember_me" style="width: auto;">
                    <label for="_remember_me" style="font-size: 0.9rem; color: var(--text-dim);">Se souvenir de moi</label>
                </div>

                <button class="btn" type="submit" style="width: 100%; padding: 0.8rem; font-size: 1rem;">
                    Se connecter
                </button>
                
                <p style="text-align: center; margin-top: 1.5rem; font-size: 0.9rem; color: var(--text-dim);">
                    Pas encore de compte ? <a href="{{ path('api_player_register_view') }}" style="color: var(--primary); text-decoration: none;">S'inscrire</a>
                </p>
            {% endif %}
        </form>
    </div>
</div>
{% endblock %}
