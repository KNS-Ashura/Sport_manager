{% extends 'base.html.twig' %}

{% block title %}Mon Dashboard - SportManager{% endblock %}

{% block body %}
<h1 style="margin-bottom: 2rem;">Bonjour, {{ app.user.firstName }} ! 👋</h1>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
    
    {# Section Matchs (Résumé) #}
    <div class="card">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h2 style="margin: 0;">⚽ Prochain Match</h2>
            <a href="{{ path('app_user_matches') }}" style="font-size: 0.9rem; color: var(--primary); text-decoration: none;">Voir tous mes matchs →</a>
        </div>
        
        {% if matches is empty %}
            <p style="color: var(--text-dim)">Aucun match prévu pour le moment.</p>
        {% else %}
            {% set nextMatch = matches|first %}
            <div style="background: rgba(255,255,255,0.03); padding: 1.5rem; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05);">
                <div style="text-align: center; margin-bottom: 1rem;">
                    <span style="font-size: 0.8rem; color: var(--primary); font-weight: 600;">{{ nextMatch.tournament.tournamentName }}</span>
                </div>
                
                <div style="display: flex; justify-content: space-around; align-items: center; margin: 1rem 0;">
                    <div style="text-align: center;">
                        <div style="font-weight: 700;">{{ nextMatch.player1.username }}</div>
                    </div>
                    <div style="font-size: 1.2rem; color: var(--text-dim)">VS</div>
                    <div style="text-align: center;">
                        <div style="font-weight: 700;">{{ nextMatch.player2.username }}</div>
                    </div>
                </div>
                
                <p style="text-align: center; font-size: 0.85rem; color: var(--text-dim);">
                    📅 {{ nextMatch.matchDate|date('d/m/Y à H:i') }}
                </p>

                <div style="margin-top: 1.5rem;">
                    <a href="{{ path('app_user_matches') }}" class="btn btn-accent" style="width: 100%; text-align: center; box-sizing: border-box;">
                        Gérer le score
                    </a>
                </div>
            </div>
        {% endif %}
    </div>

    {# Section Inscriptions (Résumé) #}
    <div class="card">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h2 style="margin: 0;">📝 Inscriptions Récentes</h2>
            <a href="{{ path('app_user_registrations') }}" style="font-size: 0.9rem; color: var(--primary); text-decoration: none;">Toutes mes inscriptions →</a>
        </div>

        {% if registrations is empty %}
            <p style="color: var(--text-dim)">Vous n'avez pas d'inscriptions en cours.</p>
        {% else %}
            <div style="display: grid; gap: 0.8rem;">
                {% for reg in registrations|slice(0, 3) %}
                    <div style="display: flex; justify-content: space-between; align-items: center; background: rgba(255,255,255,0.02); padding: 1rem; border-radius: 8px;">
                        <div style="font-weight: 600;">{{ reg.tournament.tournamentName }}</div>
                        <span style="color: {{ reg.status == 'confirmed' ? 'var(--accent)' : '#fbbf24' }}; font-size: 0.85rem; font-weight: 600;">
                            {{ reg.status|capitalize }}
                        </span>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        <h2 style="margin-top: 2.5rem;">🚀 Action</h2>
        <a href="{{ path('app_user_tournaments') }}" class="btn" style="width: 100%; text-align: center; box-sizing: border-box; padding: 1rem;">
            🔍 Découvrir les Tournois
        </a>
    </div>
</div>
{% endblock %}
